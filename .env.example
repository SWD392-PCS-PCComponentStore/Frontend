# Example environment variables for frontend
# Copy this file to .env and fill values locally (do NOT commit .env)

# Backend API base url (no trailing slash), e.g. http://localhost:5000/api
VITE_API_URL="http://localhost:5000/api"

# Optional: public keys for third-party services (placeholders)
VITE_ANALYTICS_KEY=""
VITE_SENTRY_DSN=""
